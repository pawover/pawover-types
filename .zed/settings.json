    },
    "TypeScript": {
      "prettier": {
        "allowed": false
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "formatter": [],
      "format_on_save": "on"
    },
    "TSX": {
      "prettier": {
        "allowed": false
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "formatter": [],
      "format_on_save": "on"
    }
  }
}
