{
  "name": "@pawover/types",
  "author": "pawover<pawover@outlook.com>",
  "description": "pawover's types",
  "license": "MIT",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22.20.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.14.0"
    }
  },
  "keywords": [
    "pawover",
    "pawover-types"
  ],
  "homepage": "https://github.com/pawover/pawover-types#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/pawover/pawover-types.git"
  },
  "main": "./dist/index.d.ts",
  "module": "./dist/index.d.ts",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "types": "./dist/*.d.ts"
    }
  },
  "scripts": {
    "build": "pnpm clean:output && tsdown",
    "public": "pnpm build && pnpm publish --access public",
    "check": "pnpm check:types & pnpm check:eslint & pnpm check:format",
    "check:types": "tsc",
    "check:eslint": "eslint --fix \"**/*.{js,cjs,mjs,ts,cts,mts,jsx,tsx,vue}\" --cache-location=.cache/eslint.cache.json --cache",
    "check:format": "prettier --write \"**/*.{html,json}\" --cache-location=.cache/prettier.cache.json --cache",
    "check:pack": "attw --pack .",
    "clean": "pnpm clean:cache & pnpm clean:lib & pnpm clean:output",
    "clean:cache": "rimraf .cache",
    "clean:lib": "rimraf node_modules",
    "clean:output": "rimraf dist",
    "lib:up": "taze -I -r --exclude pnpm",
    "commit": "git cz",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@pawover/eslint-rules": "0.2.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/react": "^19.2.16",
    "commitizen": "^4.3.1",
    "cz-customizable": "^7.5.4",
    "eslint": "^10.4.1",
    "eslint-plugin-antfu": "^3.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "taze": "^19.14.1",
    "tsdown": "^0.22.1",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "peerDependencies": {
    "@types/react": ">=19.2.4",
    "typescript": ">=5.9.3"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    },
    "cz-customizable": {
      "config": "cz.config.cjs"
    }
  }
}
