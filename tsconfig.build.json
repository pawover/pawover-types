{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2020"],
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "noEmit": false,
    "declaration": true,
    "declarationMap": false,
    "declarationDir": "dist/types",
    "emitDeclarationOnly": true,
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": ["src/**/*"]
}
